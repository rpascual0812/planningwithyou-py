SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# Comma-separated extra hosts (ngrok subdomain is auto-allowed when DEBUG=True)
ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=planningwithyou
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT token lifetimes
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=480
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# Mailjet
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_SEND_FROM=
MAILJET_SENDER_NAME=Planning With You

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Frontend URL used for email links
FRONTEND_URL=http://localhost:5173

# Xendit (platform account — subscription billing)
XENDIT_SECRET_KEY=
# Callback token from Xendit Dashboard → Webhooks (for payment_session.completed).
XENDIT_WEBHOOK_TOKEN=
# HTTPS frontend base for Xendit checkout return URLs (required when FRONTEND_URL is http)
# XENDIT_RETURN_URL_BASE=https://your-subdomain.ngrok-free.app

# PayMongo (platform account — booking payment links)
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
# PayMongo Platforms (linked child accounts + split). Contact PayMongo to enable.
PAYMONGO_PLATFORM_MERCHANT_ID=
PAYMONGO_PLATFORM_FEE_BPS=100
PAYMONGO_CHILD_ACCOUNT_HEADER=Paymongo-Account-Id
# Create platform child merchant (KYB)
PAYMONGO_MERCHANT_CHILDREN_URL=https://api.paymongo.com/v1/merchants/children
# Hosted merchant KYB — append merchant id, or use {merchant_id} in the template
PAYMONGO_ONBOARDING_URL=https://onboarding.paymongo.com/onboarding/merchants

# Public API base URL (Celery PDF generation, absolute file links without a request)
API_PUBLIC_BASE_URL=http://localhost:8000

# Public Django API URL (NOT the React dev server). Used for OAuth redirects and webhooks.
# Local example: http://127.0.0.1:8000  — register redirect URIs under this exact host in Google Cloud.
# Calendar client redirect: {API_PUBLIC_BASE_URL}/calendar-integrations/google/oauth/callback/
# Gmail client redirect:    {API_PUBLIC_BASE_URL}/email-integrations/gmail/oauth/callback/
GOOGLE_CALENDAR_OAUTH_CLIENT_ID=
GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=
GOOGLE_EMAIL_OAUTH_CLIENT_ID=
GOOGLE_EMAIL_OAUTH_CLIENT_SECRET=

# Password reset token lifetime (hours)
PASSWORD_RESET_TOKEN_LIFETIME_HOURS=24
EMAIL_VERIFICATION_TOKEN_LIFETIME_HOURS=72

# Document uploads — AWS S3 (set USE_S3_STORAGE=false to store files under media/ locally)
USE_S3_STORAGE=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
# Optional: MinIO / LocalStack
# AWS_S3_ENDPOINT_URL=
# Optional: CloudFront or bucket virtual-host URL for public file links
# AWS_S3_CUSTOM_DOMAIN=
# Set true if the bucket is private and URLs must be signed (expires)
AWS_S3_QUERYSTRING_AUTH=false
