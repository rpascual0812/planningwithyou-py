[Unit]
Description=Celery Worker
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/var/www/api

Environment="PATH=/var/www/api/venv/bin"

ExecStart=/var/www/api/venv/bin/celery \
    -A planningwithyou worker --loglevel=info
    --loglevel=info

Restart=always

[Install]
WantedBy=multi-user.target

sudo vim /etc/systemd/system/celery-beat.service

[Unit]
Description=Celery Beat Scheduler
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/var/www/api

Environment="PATH=/var/www/api/venv/bin"

ExecStart=/var/www/api/venv/bin/celery \
    -A planningwithyou beat \
    --loglevel=info \
    --schedule=/var/www/api/celerybeat-schedule

Restart=always

[Install]
WantedBy=multi-user.target

