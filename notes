Description=Celery Beat Scheduler
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/var/www/api

Environment="PATH=/var/www/api/venv/bin"

ExecStart=/var/www/api/venv/bin/celery \
    -A planningwithyou beat \
    --loglevel=info \
    --schedule=/var/www/api/celerybeat-schedule

Restart=always

[Install]
WantedBy=multi-user.target

# NOTE

If you later add more EC2 instances

When you scale behind the load balancer:

ALB
 ├── EC2 #1 (Django + Celery)
 ├── EC2 #2 (Django + Celery)
 └── EC2 #3 (Django + Celery)

 you should not run Celery Beat on every instance, because scheduled jobs will execute multiple times.

 Instead:
 
 ALB
  ├── EC2 #1 (Django + Celery + Beat)
  ├── EC2 #2 (Django + Celery)
  └── EC2 #3 (Django + Celery)
 
 or move Beat to its own worker instance.



