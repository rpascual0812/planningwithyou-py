[Unit]
Description=Celery Worker
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu

WorkingDirectory=/var/www/api

Environment="DJANGO_SETTINGS_MODULE=planningwithyou.settings"
Environment="PATH=/var/www/api/venv/bin"

ExecStart=/var/www/api/venv/bin/celery \
    -A planningwithyou worker \
    --loglevel=info

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target


